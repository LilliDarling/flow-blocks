node_modules/
dist/

# Environment / secrets — `.env` is committed (placeholders only); `.env.local`
# and friends are dev-machine overrides that may hold real credentials.
.env
.env.local
.env.*.local

# Source maps — never ship them; never commit them. Belt & suspenders to the
# `sourcemap: false` in vite.config.ts and `noEmit: true` in tsconfig.json.
*.map

# OS / editor cruft
.DS_Store
.idea/

# Supabase CLI scratch state (per-user, not project state)
supabase/.temp/

# Capacitor — bundled web assets are regenerated by `cap sync`
android/app/src/main/assets/public/
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/app/release/
android/app/google-services.json
android/keystore.properties
ios/App/App/public/
ios/App/build/
ios/App/Pods/
*.jks
*.keystore
keystore.properties
